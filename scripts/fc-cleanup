#!/bin/sh
# fc-cleanup — post-stop cleanup for a Firecracker VM unit.
# Called by ExecStopPost in firecracker@.service.
#
# Usage: fc-cleanup <sandbox-id>

set -eu

SANDBOX_ID="$1"
RUNDIR="/var/lib/sandbox/rundir/${SANDBOX_ID}"
SOCKET="${RUNDIR}/firecracker.sock"

# Remove the API socket if it exists.
rm -f "${SOCKET}"

echo "fc-cleanup: cleaned up ${SANDBOX_ID}"
